{
  "name": "paramount",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --production --target=bun --outdir=build --sourcemap",
    "start": "bun build/index.js",
    "fmt": "oxfmt --no-error-on-unmatched-pattern",
    "fmt:c": "oxfmt --no-error-on-unmatched-pattern --check",
    "lint": "oxlint --fix",
    "lint:c": "oxlint",
    "knip": "knip",
    "knip:p": "knip --production",
    "test": "bunx --bun vitest run",
    "test:cov": "bunx --bun vitest run --coverage",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@mikro-orm/core": "^7.0.13",
    "@mikro-orm/postgresql": "^7.0.13",
    "bullmq": "^5.76.4",
    "dotenv-flow": "^4.1.0",
    "hono": "^4.12.16",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/types": "^20.5.0",
    "@mikro-orm/cli": "^7.0.13",
    "@mikro-orm/migrations": "^7.0.13",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.6.0",
    "@types/qs": "^6.15.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "bun-types": "^1.3.13",
    "change-case": "^5.4.4",
    "husky": "^9.1.7",
    "knip": "^6.9.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "qs": "^6.15.1",
    "sql-formatter": "^15.7.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
