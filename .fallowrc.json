{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/index.ts"],
  "ignorePatterns": ["src/reset.d.ts"],
  "dynamicallyLoaded": ["src/database/_migrations/*.ts", "src/database/_seeders/*.ts"],
  "ignoreDependencies": ["@mikro-orm/cli", "@total-typescript/ts-reset"],
  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "error",
    "unused-dependencies": "error",
    "unused-dev-dependencies": "error",
    "unused-optional-dependencies": "error",
    "unused-enum-members": "off",
    "unused-class-members": "off",
    "unresolved-imports": "error",
    "unlisted-dependencies": "error",
    "duplicate-exports": "error",
    "type-only-dependencies": "warn",
    "test-only-dependencies": "warn",
    "circular-dependencies": "error",
    "boundary-violation": "error",
    "coverage-gaps": "off",
    "feature-flags": "off",
    "stale-suppressions": "warn"
  },
  "overrides": []
}
