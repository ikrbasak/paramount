{
  "cSpell.words": ["bunx", "mikro"],
  "npm.packageManager": "bun",
  "js/ts.format.semicolons": "insert",
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": true,
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.preferences.quoteStyle": "single",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.preferences.includePackageJsonAutoImports": "on",
  "editor.wordWrapColumn": 120,
  "editor.wordWrap": "off",
  "editor.renderFinalNewline": "on",
  "editor.inlayHints.enabled": "on",
  "editor.trimAutoWhitespace": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "oxc.enable": true,
  "oxc.configPath": ".oxlintrc.json",
  "oxc.fixKind": "safe_fix_or_suggestion",
  "oxc.lint.run": "onSave",
  "oxc.requireConfig": true,
  "oxc.typeAware": true,
  "oxc.unusedDisableDirectives": "deny",
  "bun.test.enable": false,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.tsserver.log": "off",
  "editor.formatOnSaveMode": "file",
  "oxc.trace.server": "verbose",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "never",
    "source.fixAll.oxc": "always",
    "source.fixAll": "always"
  },
  "knip.configFilePath": "knip.config.ts",
  "knip.requireConfig": true,
  "knip.editor.dependencies.hover.enabled": false,
  "knip.editor.exports.codelens.enabled": false,
  "knip.editor.exports.highlight.dimClassMembers": false
}
